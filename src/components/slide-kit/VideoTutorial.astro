---
const { 
  src,
  id = `video-${Math.random().toString(36).substr(2, 9)}`,
  ratio = '16/9',
  autoplay = false,
  class: className = '',
} = Astro.props;
---

<figure class={`not-prose my-4 ${className}`}>

  <div class="relative w-full" style=`aspect-ratio: ${ratio};`>
    <video
      id={id}
      src={src}
      class="w-full h-auto"
      muted
      playsinline
      autoplay={autoplay}
      loop
    ></video>

    <!-- Play/Pause Button -->
    <button
      onclick={`
        const v = document.getElementById('${id}');
        if(v.paused) { v.play(); this.textContent='⏸'; } 
        else { v.pause(); this.textContent='▶'; }
      `}
      class="absolute bottom-4 left-4 bg-black/0 text-black p-2 rounded font-mono text-2xl"
    >
      {autoplay ? '⏸' : '▶'}
    </button>
  </div>
  
</figure>
