---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  iframeSrc: string;
  showHeader?: boolean;
}

const { title, iframeSrc, showHeader = false, iframeWidth = 1000, iframeHeight = 720, iframeScale = 1 } = Astro.props;
const scaledWidth  = Math.round(iframeWidth  * iframeScale);
const scaledHeight = Math.round(iframeHeight * iframeScale);
const frameId = 'frame-' + Math.random().toString(36).slice(2);
---

<BaseLayout title={title} showHeader={showHeader}>
  <article class="mb-16 sm:mb-24">
    <header class="mb-8">
      <h1 class="text-3xl leading-tight font-serif font-medium sm:text-5xl sm:leading-tight">{title}</h1>
    </header>
    <div style={`width: ${scaledWidth}px; height: ${scaledHeight}px; overflow: hidden;`}>
      <iframe
        id={frameId}
        src={iframeSrc}
        width={iframeWidth}
        height={iframeHeight}
        style={`transform: scale(${iframeScale}); transform-origin: top left; border: none; display: block;`}
        scrolling="no"
        title={title}
      />
      <div class="prose sm:prose-lg mt-4">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>