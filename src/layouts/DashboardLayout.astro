---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';

export interface Props {
  title: string;
  iframeSrc: string;
  showHeader?: boolean;
  iframeWidth?: number;
  iframeHeight?: number;
  iframeScale?: number;
}

const { title, iframeSrc, showHeader = false, iframeWidth, iframeHeight, iframeScale = 1 } = Astro.props;
const hasFixedSize = iframeWidth !== undefined && iframeHeight !== undefined;
const scaledWidth  = hasFixedSize ? Math.round(iframeWidth * iframeScale) : null;
const scaledHeight = hasFixedSize ? Math.round(iframeHeight * iframeScale) : null;
---

<!doctype html>
<html lang="en" class="antialiased break-words">
  <head>
    <BaseHead title={title} />
  </head>
  <body class="bg-main text-main sm:px-14">
    <div class="flex flex-col min-h-screen px-4 md:px-8">
      <Nav />
      <main class="grow w-full max-w-5xl mx-auto">
        <article>
          <header class="mb-8">
            <h1 class="text-3xl leading-tight font-serif font-medium sm:text-5xl sm:leading-tight">{title}</h1>
          </header>

          {hasFixedSize ? (
            <div style={`width: ${scaledWidth}px; height: ${scaledHeight}px; overflow: hidden;`}>
              <iframe
                src={iframeSrc}
                width={iframeWidth}
                height={iframeHeight}
                style={`transform: scale(${iframeScale}); transform-origin: top left; border: none; display: block;`}
                scrolling="no"
                title={title}
              />
            </div>
          ) : (
            <iframe
              src={iframeSrc}
              scrolling="no"
              style={`width: 100%; height: ${iframeHeight ? iframeHeight + 'px' : '4000px'}; border: none; display: block; overflow: hidden;`}
              title={title}
            />
          )}

          <div class="prose prose-lg mt-8" style="width: 100%; max-width: none;">
            <slot />
          </div>
        </article>
      </main>
      <Footer />
    </div>
  </body>
</html>